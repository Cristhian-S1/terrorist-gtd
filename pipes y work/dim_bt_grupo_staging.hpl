    <sql>SELECT
    EVENTID,
    COMPCLAIM,
    MOTIVE,
    GNAME,
    GSUBNAME,
    GUNCERTAIN1 AS GUNCERTAIN,
    CLAIMED AS CLAIMED,
    CLAIMMODE,
    CLAIMMODE_TXT
FROM GTD
WHERE GNAME IS NOT NULL

UNION ALL

SELECT
    EVENTID,
    COMPCLAIM,
    MOTIVE,
    GNAME2,
    GSUBNAME2,
    GUNCERTAIN2 AS GUNCERTAIN,
    CLAIM2 AS CLAIMED,
    CLAIMMODE2 AS CLAIMMODE,
