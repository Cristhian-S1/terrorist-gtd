    GUNCERTAIN3 AS GUNCERTAIN,
    CLAIM3 AS CLAIMED,
    CLAIMMODE3 AS CLAIMMODE,
    CLAIMMODE3_TXT AS CLAIMMODE_TXT
FROM GTD
WHERE GNAME3 IS NOT NULL</sql>
