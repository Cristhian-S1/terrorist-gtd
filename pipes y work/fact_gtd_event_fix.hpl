  <transform>
    <type>TableInput</type>
    <name>Leer eventos GTD</name>
    <sql>
WITH gtd_data AS (
  SELECT
    EVENTID AS EVENT_ID, IYEAR, IMONTH, IDAY, EXTENDED, RESOLUTION,
    TO_NUMBER(TO_CHAR(
      CASE
        WHEN IYEAR IS NULL THEN NULL
        ELSE COALESCE(
          TO_DATE(
            IYEAR || '-' || LEAST(GREATEST(NVL(NULLIF(IMONTH, 0), 1), 1), 12) || '-' || NVL(NULLIF(IDAY, 0), 1)
            DEFAULT NULL ON CONVERSION ERROR,
            'YYYY-MM-DD'
          ),
          LAST_DAY(TO_DATE(IYEAR || '-' || LEAST(GREATEST(NVL(NULLIF(IMONTH, 0), 1), 1), 12) || '-01', 'YYYY-MM-DD'))
        )
      END,
      'YYYYMMDD'
    )) AS FECHA_INI_SK,
    CASE
      WHEN NVL(EXTENDED, 0) = 1 AND RESOLUTION IS NOT NULL
      THEN TO_NUMBER(
        TO_CHAR(
          CASE
            WHEN REGEXP_LIKE(RESOLUTION, '^\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2}\.\d{3}$')
            THEN TO_TIMESTAMP(RESOLUTION DEFAULT NULL ON CONVERSION ERROR, 'YYYY/MM/DD HH24:MI:SS.FF')
            WHEN REGEXP_LIKE(RESOLUTION, '^\d{4}/\d{2}/\d{2}$')
            THEN TO_DATE(RESOLUTION DEFAULT NULL ON CONVERSION ERROR, 'YYYY/MM/DD')
            ELSE NULL
          END,
          'YYYYMMDD'
        )
      )
      ELSE NULL
    END AS FECHA_RES_SK,
    COUNTRY, COUNTRY_TXT, REGION, REGION_TXT, PROVSTATE, CITY, LATITUDE, LONGITUDE,
    VICINITY, SPECIFICITY,
    CRIT1, CRIT2, CRIT3, DOUBTTERR, ALTERNATIVE, ALTERNATIVE_TXT, MULTIPLE,
    INT_LOG, INT_MISC, INT_ANY,
    WEAPTYPE1, WEAPTYPE1_TXT, WEAPSUBTYPE1, WEAPSUBTYPE1_TXT,
    WEAPTYPE2, WEAPTYPE2_TXT, WEAPSUBTYPE2, WEAPSUBTYPE2_TXT,
    WEAPTYPE3, WEAPTYPE3_TXT, WEAPSUBTYPE3, WEAPSUBTYPE3_TXT,
    WEAPTYPE4, WEAPTYPE4_TXT, WEAPSUBTYPE4, WEAPSUBTYPE4_TXT,
    ATTACKTYPE1, ATTACKTYPE1_TXT, ATTACKTYPE2, ATTACKTYPE2_TXT,
    ATTACKTYPE3, ATTACKTYPE3_TXT, SUCCESS, SUICIDE,
    TARGTYPE1, TARGTYPE1_TXT, TARGSUBTYPE1, TARGSUBTYPE1_TXT,
    CORP1, TARGET1, NATLTY1, NATLTY1_TXT,
    TARGTYPE2, TARGTYPE2_TXT, TARGSUBTYPE2, TARGSUBTYPE2_TXT,
    CORP2, TARGET2, NATLTY2, NATLTY2_TXT,
    TARGTYPE3, TARGTYPE3_TXT, TARGSUBTYPE3, TARGSUBTYPE3_TXT,
    CORP3, TARGET3, NATLTY3, NATLTY3_TXT,
    PROPERTY, PROPEXTENT, PROPEXTENT_TXT, ISHOSTKID, HOSTKIDOUTCOME, HOSTKIDOUTCOME_TXT,
    GNAME, GSUBNAME, GNAME2, GSUBNAME2, GNAME3, GSUBNAME3,
    MOTIVE, COMPCLAIM, GUNCERTAIN1, GUNCERTAIN2, GUNCERTAIN3,
    CLAIMED, CLAIMMODE, CLAIMMODE_TXT,
    CLAIM2, CLAIMMODE2, CLAIMMODE2_TXT,
    CLAIM3, CLAIMMODE3, CLAIMMODE3_TXT,
    INDIVIDUAL,
    NKILL, NKILLUS, NKILLTER,
    NWOUND, NWOUNDUS, NWOUNDTE,
    NPERPS, NPERPCAP, NHOSTKID, NHOSTKIDUS,
    NRELEASED, NHOURS, NDAYS,
    RANSOMAMT, RANSOMAMTUS, RANSOMPAID, RANSOMPAIDUS, PROPVALUE
  FROM GTD
)
SELECT
  g.*,
  NVL(t1.TIEMPO_SK, -1) AS FK_FECHA_INI,
  NVL(t2.TIEMPO_SK, -1) AS FK_FECHA_RES,
  NVL(l.LUGAR_SK, -1) AS FK_LUGAR,
  NVL(sl.SPEC_LUGAR_SK, -1) AS FK_LUGAR_SPEC,
  NVL(d.DETALLE_SK, -1) AS FK_DETALLES,
  NVL(da.DETALLES_A_SK, -1) AS FK_DETALLES_ADICIONALES,
  NVL(at.ATAQUE_SK, -1) AS FK_ATAQUE,
  NVL(a1.ARMAS_SK, -1) AS FK_ARMA1,
  NVL(a2.ARMAS_SK, -1) AS FK_ARMA2,
  NVL(a3.ARMAS_SK, -1) AS FK_ARMA3,
  NVL(a4.ARMAS_SK, -1) AS FK_ARMA4,
  NVL(o1.OBJETIVO_SK, -1) AS FK_OBJ1,
  NVL(o2.OBJETIVO_SK, -1) AS FK_OBJ2,
  NVL(o3.OBJETIVO_SK, -1) AS FK_OBJ3,
  NVL(i.IMPACTO_SK, -1) AS FK_IMPACTO,
  NVL(p1.PERP_SK, -1) AS PERP_FK1,
  NVL(p2.PERP_SK, -1) AS PERP_FK2,
  NVL(p3.PERP_SK, -1) AS PERP_FK3,
  NVL(m1.MCR_SK, -1) AS MCR_FK1,
  NVL(m2.MCR_SK, -1) AS MCR_FK2,
  NVL(m3.MCR_SK, -1) AS MCR_FK3,
  NVL(g.CLAIMED, -1) AS CLAIMED1,
  NVL(g.CLAIM2, -1) AS CLAIMED2,
  NVL(g.CLAIM3, -1) AS CLAIMED3
FROM gtd_data g
LEFT JOIN DIM_TIEMPO t1 ON t1.TIEMPO_SK = g.FECHA_INI_SK
LEFT JOIN DIM_TIEMPO t2 ON t2.TIEMPO_SK = g.FECHA_RES_SK
LEFT JOIN (
  SELECT MAX(LUGAR_SK) AS LUGAR_SK, COUNTRY_TXT, REGION_TXT, PROVSTATE, CITY
  FROM DIM_LUGAR
  WHERE VALID_TO IS NULL
  GROUP BY COUNTRY_TXT, REGION_TXT, PROVSTATE, CITY
) l
  ON l.COUNTRY_TXT = NVL(g.COUNTRY_TXT, 'Unknown')
 AND l.REGION_TXT = NVL(g.REGION_TXT, 'Unknown')
 AND l.PROVSTATE = NVL(g.PROVSTATE, 'Unknown')
 AND l.CITY = NVL(g.CITY, 'Unknown')
LEFT JOIN (
  SELECT MAX(SPEC_LUGAR_SK) AS SPEC_LUGAR_SK, VICINITY, SPECIFY
  FROM DIM_ESPEC_LUGAR
  GROUP BY VICINITY, SPECIFY
) sl
  ON sl.VICINITY = NVL(g.VICINITY, -1)
 AND sl.SPECIFY = NVL(g.SPECIFICITY, -1)
LEFT JOIN (
  SELECT MAX(DETALLE_SK) AS DETALLE_SK, CRIT1, CRIT2, CRIT3, DOUBTTERR, ALTERNATIVE
  FROM DIM_DETALLE
  GROUP BY CRIT1, CRIT2, CRIT3, DOUBTTERR, ALTERNATIVE
) d
  ON d.CRIT1 = NVL(g.CRIT1, -1)
 AND d.CRIT2 = NVL(g.CRIT2, -1)
 AND d.CRIT3 = NVL(g.CRIT3, -1)
 AND d.DOUBTTERR = NVL(g.DOUBTTERR, -1)
 AND d.ALTERNATIVE = NVL(g.ALTERNATIVE, -1)
LEFT JOIN (
  SELECT MAX(DETALLES_A_SK) AS DETALLES_A_SK, INT_LOG, INT_MISC, INT_ANY
  FROM DIM_DETALLES_A
  GROUP BY INT_LOG, INT_MISC, INT_ANY
) da
  ON da.INT_LOG = NVL(g.INT_LOG, -1)
 AND da.INT_MISC = NVL(g.INT_MISC, -1)
 AND da.INT_ANY = NVL(g.INT_ANY, -1)
LEFT JOIN (
  SELECT MAX(ATAQUE_SK) AS ATAQUE_SK, ATTACKTYPE1, SUCCESS, SUICIDE
  FROM DIM_ATAQUE
  GROUP BY ATTACKTYPE1, SUCCESS, SUICIDE
) at
  ON at.ATTACKTYPE1 = NVL(g.ATTACKTYPE1, -1)
 AND at.SUCCESS = NVL(g.SUCCESS, -1)
 AND at.SUICIDE = NVL(g.SUICIDE, -1)
LEFT JOIN (
  SELECT MAX(ARMAS_SK) AS ARMAS_SK, WEAPTYPE, WEAPSUBTYPE
  FROM DIM_ARMAS
  GROUP BY WEAPTYPE, WEAPSUBTYPE
) a1
  ON a1.WEAPTYPE = NVL(g.WEAPTYPE1, -1)
 AND a1.WEAPSUBTYPE = NVL(g.WEAPSUBTYPE1, -1)
LEFT JOIN (
  SELECT MAX(ARMAS_SK) AS ARMAS_SK, WEAPTYPE, WEAPSUBTYPE
  FROM DIM_ARMAS
  GROUP BY WEAPTYPE, WEAPSUBTYPE
) a2
  ON a2.WEAPTYPE = NVL(g.WEAPTYPE2, -1)
 AND a2.WEAPSUBTYPE = NVL(g.WEAPSUBTYPE2, -1)
LEFT JOIN (
  SELECT MAX(ARMAS_SK) AS ARMAS_SK, WEAPTYPE, WEAPSUBTYPE
  FROM DIM_ARMAS
  GROUP BY WEAPTYPE, WEAPSUBTYPE
) a3
  ON a3.WEAPTYPE = NVL(g.WEAPTYPE3, -1)
 AND a3.WEAPSUBTYPE = NVL(g.WEAPSUBTYPE3, -1)
LEFT JOIN (
  SELECT MAX(ARMAS_SK) AS ARMAS_SK, WEAPTYPE, WEAPSUBTYPE
  FROM DIM_ARMAS
  GROUP BY WEAPTYPE, WEAPSUBTYPE
) a4
  ON a4.WEAPTYPE = NVL(g.WEAPTYPE4, -1)
 AND a4.WEAPSUBTYPE = NVL(g.WEAPSUBTYPE4, -1)
LEFT JOIN (
  SELECT MAX(OBJETIVO_SK) AS OBJETIVO_SK, TARGTYPE, TARGSUBTYPE, CORP, TARGET, NATLTY
  FROM DIM_OBJETIVOS
  GROUP BY TARGTYPE, TARGSUBTYPE, CORP, TARGET, NATLTY
) o1
  ON o1.TARGTYPE = NVL(g.TARGTYPE1, -1)
 AND o1.TARGSUBTYPE = NVL(g.TARGSUBTYPE1, -1)
 AND o1.CORP = NVL(g.CORP1, 'Unknown')
 AND o1.TARGET = NVL(g.TARGET1, 'Unknown')
 AND o1.NATLTY = NVL(g.NATLTY1, -1)
LEFT JOIN (
  SELECT MAX(OBJETIVO_SK) AS OBJETIVO_SK, TARGTYPE, TARGSUBTYPE, CORP, TARGET, NATLTY
  FROM DIM_OBJETIVOS
  GROUP BY TARGTYPE, TARGSUBTYPE, CORP, TARGET, NATLTY
) o2
  ON o2.TARGTYPE = NVL(g.TARGTYPE2, -1)
 AND o2.TARGSUBTYPE = NVL(g.TARGSUBTYPE2, -1)
 AND o2.CORP = NVL(g.CORP2, 'Unknown')
 AND o2.TARGET = NVL(g.TARGET2, 'Unknown')
 AND o2.NATLTY = NVL(g.NATLTY2, -1)
LEFT JOIN (
  SELECT MAX(OBJETIVO_SK) AS OBJETIVO_SK, TARGTYPE, TARGSUBTYPE, CORP, TARGET, NATLTY
  FROM DIM_OBJETIVOS
  GROUP BY TARGTYPE, TARGSUBTYPE, CORP, TARGET, NATLTY
) o3
  ON o3.TARGTYPE = NVL(g.TARGTYPE3, -1)
 AND o3.TARGSUBTYPE = NVL(g.TARGSUBTYPE3, -1)
 AND o3.CORP = NVL(g.CORP3, 'Unknown')
 AND o3.TARGET = NVL(g.TARGET3, 'Unknown')
 AND o3.NATLTY = NVL(g.NATLTY3, -1)
LEFT JOIN (
  SELECT MAX(IMPACTO_SK) AS IMPACTO_SK, PROPERTY, PROPEXTENT, ISHOSTKID, HOSTKIDOUTCOME
  FROM DIM_IMPACTO
  GROUP BY PROPERTY, PROPEXTENT, ISHOSTKID, HOSTKIDOUTCOME
) i
  ON i.PROPERTY = NVL(g.PROPERTY, -1)
 AND i.PROPEXTENT = NVL(g.PROPEXTENT, -1)
 AND i.ISHOSTKID = NVL(g.ISHOSTKID, -1)
 AND i.HOSTKIDOUTCOME = NVL(g.HOSTKIDOUTCOME, -1)
LEFT JOIN (
  SELECT MAX(PERP_SK) AS PERP_SK, GNAME, GSUBNAME
  FROM DIM_PERPETRADORES
  GROUP BY GNAME, GSUBNAME
) p1
  ON p1.GNAME = NVL(g.GNAME, 'Unknown')
 AND p1.GSUBNAME = NVL(g.GSUBNAME, 'Unknown')
LEFT JOIN (
  SELECT MAX(PERP_SK) AS PERP_SK, GNAME, GSUBNAME
  FROM DIM_PERPETRADORES
  GROUP BY GNAME, GSUBNAME
) p2
  ON p2.GNAME = NVL(g.GNAME2, 'Unknown')
 AND p2.GSUBNAME = NVL(g.GSUBNAME2, 'Unknown')
LEFT JOIN (
  SELECT MAX(PERP_SK) AS PERP_SK, GNAME, GSUBNAME
  FROM DIM_PERPETRADORES
  GROUP BY GNAME, GSUBNAME
) p3
  ON p3.GNAME = NVL(g.GNAME3, 'Unknown')
 AND p3.GSUBNAME = NVL(g.GSUBNAME3, 'Unknown')
LEFT JOIN (
  SELECT MAX(MCR_SK) AS MCR_SK, CLAIMMODE, CLAIMMODE_TXT
  FROM DIM_MCR
  GROUP BY CLAIMMODE, CLAIMMODE_TXT
) m1
  ON m1.CLAIMMODE = NVL(g.CLAIMMODE, -1)
 AND m1.CLAIMMODE_TXT = NVL(g.CLAIMMODE_TXT, 'Unknown')
LEFT JOIN (
  SELECT MAX(MCR_SK) AS MCR_SK, CLAIMMODE, CLAIMMODE_TXT
  FROM DIM_MCR
  GROUP BY CLAIMMODE, CLAIMMODE_TXT
) m2
  ON m2.CLAIMMODE = NVL(g.CLAIMMODE2, -1)
 AND m2.CLAIMMODE_TXT = NVL(g.CLAIMMODE2_TXT, 'Unknown')
LEFT JOIN (
  SELECT MAX(MCR_SK) AS MCR_SK, CLAIMMODE, CLAIMMODE_TXT
  FROM DIM_MCR
  GROUP BY CLAIMMODE, CLAIMMODE_TXT
) m3
  ON m3.CLAIMMODE = NVL(g.CLAIMMODE3, -1)
 AND m3.CLAIMMODE_TXT = NVL(g.CLAIMMODE3_TXT, 'Unknown')
</sql>
