    <type>TableInput</type>
    <name>TI_DENORMALIZED</name>
    <sql>SELECT 
  G.GRUPO_SK,
  DBMS_LOB.SUBSTR(D.MOTIVE, 4000, 1) AS MOTIVE,
  D.COMPCLAIM,
  D.PERP_FK1,
  D.MCR_FK1,
  D.CLAIMED1,
  D.GUNCERTAIN1,
  D.PERP_FK2,
  D.MCR_FK2,
  D.CLAIMED2,
  D.GUNCERTAIN2,
  D.PERP_FK3,
  D.MCR_FK3,
  D.CLAIMED3,
  D.GUNCERTAIN3
FROM DENORMALIZED_DATA_DIM D
JOIN DIM_GPERP G
  ON DBMS_LOB.SUBSTR(G.MOTIVE, 4000, 1) = DBMS_LOB.SUBSTR(D.MOTIVE, 4000, 1)
  AND G.COMPCLAIM = D.COMPCLAIM</sql>
